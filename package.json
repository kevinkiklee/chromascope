{
  "name": "chromascope",
  "private": true,
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "packages/*",
    "plugins/*",
    "apps/*"
  ],
  "devDependencies": {
    "turbo": "^2"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "build:plugins": "bash scripts/build-plugins.sh"
  }
}
